# Base de datos PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/alertacomunal"

# Secret para JWT — OBLIGATORIO en producción
# Generar con: openssl rand -base64 32
JWT_SECRET="tu-secreto-jwt-muy-seguro-cambiar-en-produccion"

# URL de la aplicación
APP_URL="http://localhost:3000"

# Municipalidad por defecto para reportes ciudadanos
PUBLIC_DEFAULT_MUNICIPALITY_SLUG=demo

# ─── Almacenamiento de archivos ───────────────────────────────────────────────
# 'local' → guarda en public/uploads (no persistente en Railway sin Volumen)
# 's3'    → MinIO o cualquier storage compatible con S3
STORAGE_PROVIDER=local

# Tamaño máximo de upload en MB
MAX_UPLOAD_SIZE_MB=5

# ─── MinIO / S3 (solo si STORAGE_PROVIDER=s3) ────────────────────────────────
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=

# ─── Google Maps (geocodificación de direcciones) ────────────────────────────
# Activar en Google Cloud Console: Maps JavaScript API + Places API + Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Notificaciones por correo (Resend) ──────────────────────────────────────
# EMAIL_ENABLED=true activa el envío. Si es false o no está, no se envían correos.
# RESEND_API_KEY es obligatoria solo si EMAIL_ENABLED=true.
# El dominio de EMAIL_FROM debe estar verificado en Resend.
RESEND_API_KEY=
EMAIL_FROM=tecnico@elementalpro.cl
EMAIL_ENABLED=false

# NO agregar NODE_ENV — se gestiona automáticamente en el build script
