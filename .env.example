# Base de datos PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/alertacomunal"

# Secret para JWT — OBLIGATORIO en producción
# Generar con: openssl rand -base64 32
JWT_SECRET="tu-secreto-jwt-muy-seguro-cambiar-en-produccion"

# URL de la aplicación
APP_URL="http://localhost:3000"

# Municipalidad por defecto para reportes ciudadanos
PUBLIC_DEFAULT_MUNICIPALITY_SLUG=demo

# Almacenamiento de archivos (solo 'local' por ahora)
STORAGE_PROVIDER=local

# Tamaño máximo de upload en MB
MAX_UPLOAD_SIZE_MB=5

# NO agregar NODE_ENV — se gestiona automáticamente en el build script
